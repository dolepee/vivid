# DGrid AI Gateway (primary AI, https://dgrid.ai)
DGRID_API_KEY=your_dgrid_api_key

# Upstash Redis (session persistence, auto-provisioned via Vercel KV integration)
KV_REST_API_URL=your_upstash_rest_url
KV_REST_API_TOKEN=your_upstash_rest_token

# BNB Chain soul proof (deploy with `npm run deploy:soul`)
NEXT_PUBLIC_VIVID_SOUL_REGISTRY_ADDRESS=0x...
BNB_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
DEPLOYER_PRIVATE_KEY=your_testnet_deployer_private_key

# Telegram activation (set webhook to /api/telegram/webhook)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
